<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9
                  https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <changeSet id="20231204-create-consultation-workflow-config-table" author="eudson">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="consultationworkflow_workflow_config"/>
            </not>
        </preConditions>
        <createTable tableName="consultationworkflow_workflow_config">
            <column name="workflow_config_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(1000)">
                <constraints nullable="false"/>
            </column>
            <column name="published" type="boolean" defaultValueBoolean="false"/>
            <column name="version" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="creator" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="changed_by" type="int"/>
            <column name="date_changed" type="datetime"/>
            <column name="voided" type="boolean" defaultValueBoolean="false"/>
            <column name="voided_by" type="int"/>
            <column name="date_voided" type="datetime"/>
            <column name="void_reason" type="varchar(255)"/>
            <column name="uuid" type="char(38)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20231204-create-consultation-workflow-data-table" author="eudson">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="consultationworkflow_workflow_data"/>
            </not>
        </preConditions>
        <createTable tableName="consultationworkflow_workflow_data">
            <column name="workflow_data_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="workflow_config_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="visit_id" type="int"/>
            <column name="creator" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="changed_by" type="int"/>
            <column name="date_changed" type="datetime"/>
            <column name="voided" type="boolean" defaultValueBoolean="false"/>
            <column name="voided_by" type="int"/>
            <column name="date_voided" type="datetime"/>
            <column name="void_reason" type="varchar(255)"/>
            <column name="uuid" type="char(38)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
        <addForeignKeyConstraint constraintName="workflow_data_config_id_fk"
                                 baseTableName="consultationworkflow_workflow_data" baseColumnNames="workflow_config_id"
                                 referencedTableName="consultationworkflow_workflow_config"
                                 referencedColumnNames="workflow_config_id"/>
        <addForeignKeyConstraint constraintName="workflow_data_patient_id_fk"
                                 baseTableName="consultationworkflow_workflow_data" baseColumnNames="patient_id"
                                 referencedTableName="patient" referencedColumnNames="patient_id"/>
        <addForeignKeyConstraint constraintName="workflow_data_visit_id_fk"
                                 baseTableName="consultationworkflow_workflow_data" baseColumnNames="visit_id"
                                 referencedTableName="visit" referencedColumnNames="visit_id"/>
    </changeSet>

    <changeSet id="20231204-create-workflow-step-data-table" author="eudson">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="consultationworkflow_workflow_step_data"/>
            </not>
        </preConditions>
        <createTable tableName="consultationworkflow_workflow_step_data">
            <column name="workflow_step_data_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="workflow_data_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="step_id" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="stepName" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="renderType" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="data_reference" type="varchar(255)"/>
            <column name="completed" type="boolean" defaultValueBoolean="false"/>
            <column name="creator" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="changed_by" type="int"/>
            <column name="date_changed" type="datetime"/>
            <column name="voided" type="boolean" defaultValueBoolean="false"/>
            <column name="voided_by" type="int"/>
            <column name="date_voided" type="datetime"/>
            <column name="void_reason" type="varchar(255)"/>
            <column name="uuid" type="char(38)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
        <addForeignKeyConstraint constraintName="workflow_step_data_workflow_id_fk"
                                 baseTableName="consultationworkflow_workflow_step_data"
                                 baseColumnNames="workflow_data_id"
                                 referencedTableName="consultationworkflow_workflow_data"
                                 referencedColumnNames="workflow_data_id"/>
    </changeSet>

    <changeSet id="20231204-create-workflow-eligibility-criteria-table" author="eudson">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="consultationworkflow_eligibility_criteria"/>
            </not>
        </preConditions>
        <createTable tableName="consultationworkflow_eligibility_criteria">
            <column name="eligibility_criteria_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="criteria_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="condition" type="varchar(1000)">
                <constraints nullable="false"/>
            </column>
            <column name="workflow_config_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="creator" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="changed_by" type="int"/>
            <column name="date_changed" type="datetime"/>
            <column name="voided" type="boolean" defaultValueBoolean="false"/>
            <column name="voided_by" type="int"/>
            <column name="date_voided" type="datetime"/>
            <column name="void_reason" type="varchar(255)"/>
            <column name="uuid" type="char(38)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
        <addForeignKeyConstraint constraintName="eligibility_workflow_config_id_fk"
                                 baseTableName="consultationworkflow_eligibility_criteria"
                                 baseColumnNames="workflow_config_id"
                                 referencedTableName="consultationworkflow_workflow_config"
                                 referencedColumnNames="workflow_config_id"/>
    </changeSet>
</databaseChangeLog>